# ID модулей Tourvisor.
# Где взять: кабинет партнёра pro.tourvisor.ru -> «Модули для сайта».
# Создайте модуль нужного типа и скопируйте число из строки tv-moduleid-XXXXXXX.

# Модуль «Поиск туров» (хиро-блок на главной)
NEXT_PUBLIC_TV_SEARCH_ID=9955693

# Модуль «Горящие туры» — превью на главной
NEXT_PUBLIC_TV_HOT_HOME_ID=9955326

# Модуль «Горящие туры» — полная выдача на странице /hot-tours
NEXT_PUBLIC_TV_HOT_PAGE_ID=9955327

# Уведомления о заявках в Telegram (серверные секреты — без NEXT_PUBLIC_!).
# Токен бота: напишите @BotFather в Telegram -> /newbot -> скопируйте токен.
# ID чата: напишите своему боту любое сообщение, затем откройте
# https://api.telegram.org/bot<ТОКЕН>/getUpdates — число в "chat":{"id":...}
# и есть ваш chat_id. Если переменные не заданы, заявки просто пишутся
# в серверный лог, сайт работает как обычно.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
